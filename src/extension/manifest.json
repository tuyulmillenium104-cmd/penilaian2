{
  "manifest_version": 3,
  "name": "Quiz Helper",
  "version": "12.1.0",
  "description": "Real-time Quiz Solver with URL Pattern Targeting. Select website to monitor. Capture + Vision AI for instant answers.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quiz Helper v12.1"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}

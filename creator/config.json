{
  "name": "creator-workflow",
  "version": "2.0.0",
  "description": "Content Creator Workflow for Rally.fun - Build to Pass, Create to Beat",
  "type": "workflow",
  "lastUpdated": "2026-03-21",

  "philosophy": {
    "core": "Build content that PASS all judging criteria, BEAT the leaderboard, and stand out from competitors",
    "principles": [
      "Originality = Life",
      "Emotion = Engagement",
      "Hook = First Impression",
      "CTA = Conversation",
      "No Fluff",
      "Beat the Leaderboard"
    ]
  },

  "requiredElements": {
    "hook": {
      "required": true,
      "description": "Power pattern opening, bukan template",
      "validation": {
        "minLength": 10,
        "maxLength": 200,
        "mustBePowerPattern": true,
        "noWeakOpening": true
      }
    },
    "emotion": {
      "required": true,
      "description": "Minimal 3 emotion types + 1 body feeling",
      "validation": {
        "minTypes": 3,
        "requireBodyFeeling": true
      }
    },
    "cta": {
      "required": true,
      "description": "Question yang mengajak respond",
      "validation": {
        "mustBeQuestion": true,
        "minElements": 3
      }
    },
    "requiredUrl": {
      "required": true,
      "description": "URL dari campaign, natural placement",
      "validation": {
        "mustInclude": true
      }
    },
    "facts": {
      "required": true,
      "description": "Fresh data dari web search",
      "validation": {
        "minCount": 2,
        "mustBeFromWebSearch": true
      }
    },
    "bodyFeelings": {
      "required": true,
      "description": "Untuk emotion score tinggi (10)",
      "validation": {
        "minCount": 1
      }
    }
  },

  "leaderboardIntelligence": {
    "enabled": true,
    "description": "Analisis leaderboard untuk beat strategy",
    "analysisPoints": {
      "topContentCount": 5,
      "extractHookPatterns": true,
      "extractEmotions": true,
      "extractStructure": true,
      "extractAngles": true
    },
    "gapAnalysis": {
      "identifyMissingHookPatterns": true,
      "identifyMissingEmotions": true,
      "identifyMissingBodyFeelings": true,
      "identifyFreshDataNeeded": true
    },
    "beatStrategy": {
      "targetScoreAboveRank1": true,
      "useDifferentiator": true,
      "uniqueAngleRequired": true
    }
  },

  "externalDataCollection": {
    "enabled": true,
    "description": "Web search untuk data fresh",
    "sources": {
      "freshFacts": {
        "enabled": true,
        "description": "Data/angka terbaru"
      },
      "caseStudies": {
        "enabled": true,
        "description": "Contoh nyata"
      },
      "quotes": {
        "enabled": true,
        "description": "Statement kredibel"
      },
      "trends": {
        "enabled": true,
        "description": "Trend terkini"
      },
      "verification": {
        "enabled": true,
        "description": "Verifikasi fakta"
      }
    }
  },

  "input": {
    "campaignData": {
      "source": "file | api",
      "path": "/download/campaign-data.json",
      "required": ["title", "knowledgeBase", "rules", "requiredUrl"],
      "optional": ["style", "missions", "rewards"]
    },
    "leaderboardData": {
      "source": "api",
      "path": "/download/leaderboard-data.json",
      "required": true,
      "description": "Top content untuk analysis"
    },
    "competitorHooks": {
      "source": "api | file",
      "path": "/download/competitor-hooks.json",
      "description": "Hooks yang sudah digunakan (untuk dihindari)"
    },
    "externalData": {
      "source": "web_search",
      "description": "Data fresh dari web search"
    }
  },

  "output": {
    "path": "/download/creator-output/",
    "files": {
      "content-versions.json": "Semua versi konten dengan prediksi score",
      "leaderboard-analysis.json": "Hasil analisis leaderboard",
      "external-data.json": "Data dari web search"
    }
  },

  "hookPatterns": {
    "priority": ["personal_pain", "contrarian", "number_problem", "bold_statement", "question_tension"],
    "patterns": {
      "number_problem": {
        "description": "Angka + masalah",
        "examples": ["$50M locked. No key.", "2.3 billion dollars. Zero judges."],
        "scorePotential": "8-10"
      },
      "bold_statement": {
        "description": "Pernyataan berani",
        "examples": ["Code runs. Justice doesn't.", "Execution without resolution isn't justice."],
        "scorePotential": "8-10"
      },
      "question_tension": {
        "description": "Pertanyaan + ketegangan",
        "examples": ["What happens when your smart contract disagrees with you?"],
        "scorePotential": "8-10"
      },
      "personal_pain": {
        "description": "Pengalaman pribadi yang menyakitkan",
        "examples": ["My heart sank when the tx confirmed.", "I watched $10K vanish into a black hole."],
        "scorePotential": "9-10",
        "differentiator": "Sering belum ada di leaderboard"
      },
      "contrarian": {
        "description": "Pandangan berlawanan dengan mainstream",
        "examples": ["Everyone's wrong about dispute resolution.", "The 'code is law' narrative has a fatal flaw."],
        "scorePotential": "8-10",
        "differentiator": "Sering belum ada di leaderboard"
      }
    }
  },

  "contentStructure": {
    "flexible": true,
    "options": {
      "single_tweet": {
        "tweets": 1,
        "description": "Untuk info simple/announcement",
        "maxChars": 280,
        "structure": ["Hook + Setup + Facts + URL + CTA"]
      },
      "short_thread": {
        "tweets": 3,
        "description": "Single concept, focused message",
        "structure": ["Hook + Setup", "Body + Facts + URL", "CTA"]
      },
      "standard_thread": {
        "tweets": 5,
        "description": "Most campaigns - PALING UMUM",
        "structure": ["Hook + Setup", "Body - Problem/Pain", "Body - Facts + URL", "Body - Solution/Hope", "CTA"]
      },
      "long_thread": {
        "tweets": 7,
        "description": "Complex story, detailed analysis",
        "structure": ["Hook + Setup", "Problem elaboration 1", "Problem elaboration 2", "Solution/Facts + URL", "Additional facts", "Emotion peak", "CTA"]
      }
    },
    "determinationFactors": [
      "Kompleksitas topik",
      "Jumlah data/fakta",
      "Story depth",
      "Campaign requirements"
    ]
  },

  "blacklist": {
    "weakOpenings": {
      "penalty": "auto_fail_hook",
      "list": [
        "the ", "a ", "an ", "this is", "there are", "there is",
        "i think", "in the", "today ", "so ", "well ",
        "basically", "honestly ", "actually ", "first ",
        "let me", "here is", "here are"
      ]
    },
    "aiPatternWords": {
      "penalty": -2,
      "perOccurrence": true,
      "list": [
        "delve", "leverage", "realm", "tapestry", "paradigm",
        "landscape", "nuance", "underscores", "pivotal", "crucial"
      ]
    },
    "aiPatternPhrases": {
      "penalty": -2,
      "perOccurrence": true,
      "list": [
        "picture this", "lets dive in", "in this thread", "key takeaways",
        "heres the thing", "imagine a world", "it goes without saying",
        "at the end of the day"
      ]
    },
    "templateHooks": {
      "penalty": -3,
      "perOccurrence": true,
      "list": [
        "unpopular opinion", "hot take", "thread alert", "breaking",
        "this is your sign", "psa", "reminder that", "quick thread",
        "important thread", "drop everything", "stop scrolling",
        "hear me out", "let me explain", "nobody is talking about", "story time"
      ]
    },
    "bannedWords": {
      "penalty": "auto_fail_g3",
      "list": [
        "guaranteed", "guarantee", "100%", "risk-free", "sure thing",
        "financial advice", "investment advice", "buy now", "sell now",
        "get rich", "quick money", "easy money", "passive income",
        "follow me", "subscribe to my", "check my profile",
        "click here", "limited time offer", "act now",
        "legally binding", "court order", "official ruling"
      ]
    },
    "emDashes": {
      "penalty": "auto_fail_g3",
      "description": "Tidak boleh ada '—' di konten"
    },
    "prohibitedElements": {
      "penalty": "auto_fail_g3",
      "list": ["Thread 🧵", "excess hashtags (>3)", "(1/X) numbering"]
    }
  },

  "emotionTypes": {
    "fear": {
      "keywords": ["risk", "danger", "threat", "warning", "scary", "terrifying", "afraid", "worried", "nightmare", "silence", "no judge", "no appeal", "no recourse"],
      "bodyFeelings": ["cold sweat", "panic", "anxiety", "heart racing"]
    },
    "curiosity": {
      "keywords": ["wonder", "curious", "secret", "hidden", "mystery", "discover", "surprising", "unexpected", "what happens", "consider what"],
      "triggers": ["what if", "why", "how", "what happens when"]
    },
    "surprise": {
      "keywords": ["unexpected", "shocking", "surprised", "blew my mind", "plot twist", "wait what", "finally", "breakthrough", "nobody talks", "gap", "forgot"],
      "triggers": ["nobody talks about", "forgot", "gap in the market"]
    },
    "hope": {
      "keywords": ["finally", "breakthrough", "opportunity", "potential", "future", "imagine", "possible", "building", "solution"],
      "triggers": ["building", "solution", "infrastructure"]
    },
    "pain": {
      "keywords": ["lost", "failed", "broke", "destroyed", "killed", "wasted", "missed", "regret", "hurt", "pain", "dispute", "problem", "chaos"],
      "bodyFeelings": ["stomach dropped", "heart sank", "chest tightened"]
    },
    "urgency": {
      "keywords": ["now", "today", "immediately", "urgent", "quickly", "fast", "running out", "years", "seconds"],
      "triggers": ["years vs seconds", "gap widening"]
    }
  },

  "bodyFeelings": {
    "required": true,
    "list": [
      "cold sweat", "panic", "anxiety", "heart racing",
      "stomach dropped", "heart sank", "chest tightened",
      "jaw dropped", "couldn't believe"
    ]
  },

  "ctaElements": {
    "question": { "points": 2, "description": "Pertanyaan (?)" },
    "replyBait": { "points": 2, "description": "What do you think? Have you ever...?" },
    "engagementHook": { "points": 2, "description": "Drop your experience below" },
    "personal": { "points": 1, "description": "I want to hear your story" },
    "fomo": { "points": 1, "description": "before it's too late, now" },
    "controversy": { "points": 1, "description": "Who's wrong here?" },
    "shareWorthy": { "points": 1, "description": "Share this with someone who..." },
    "targetScore": 8
  },

  "targetScores": {
    "gateUtama": {
      "target": 17,
      "max": 20,
      "breakdown": {
        "G1_contentAlignment": 5,
        "G2_informationAccuracy": 5,
        "G3_campaignCompliance": 5,
        "G4_originality": 4
      }
    },
    "gateTambahan": {
      "target": 15,
      "max": 16,
      "breakdown": {
        "G5_engagementPotential": 8,
        "G6_technicalQuality": 7
      }
    },
    "penilaianInternal": {
      "target": 56,
      "max": 60,
      "breakdown": {
        "hookScore": 10,
        "emotionScore": 10,
        "ctScore": 9,
        "uniquenessScore": 10,
        "readabilityScore": 9,
        "viralPotentialScore": 8
      }
    },
    "totalTarget": 88
  },

  "flow": [
    {
      "step": 1,
      "name": "Load Campaign Data",
      "action": "read file / fetch API",
      "output": "campaignData"
    },
    {
      "step": 2,
      "name": "Load Leaderboard Data",
      "action": "fetch from Rally API",
      "output": "leaderboardTop5"
    },
    {
      "step": 3,
      "name": "Load Competitor Hooks",
      "action": "read file / fetch API",
      "output": "competitorHooks"
    },
    {
      "step": 4,
      "name": "Leaderboard Analysis",
      "action": "analyze patterns, emotions, angles",
      "output": "gapAnalysis"
    },
    {
      "step": 5,
      "name": "Web Search for Fresh Data",
      "action": "search for facts, case studies, trends",
      "output": "externalData"
    },
    {
      "step": 6,
      "name": "Determine Beat Strategy",
      "action": "choose differentiator, unique angle",
      "output": "beatStrategy"
    },
    {
      "step": 7,
      "name": "Generate Content Versions",
      "action": "create multiple versions with different approaches",
      "output": "contentVersions"
    },
    {
      "step": 8,
      "name": "Self-Check Each Version",
      "action": "validate required elements, blacklist, target scores",
      "output": "validatedVersions"
    },
    {
      "step": 9,
      "name": "Predict Scores",
      "action": "calculate predicted judge scores",
      "output": "scorePredictions"
    },
    {
      "step": 10,
      "name": "Recommend Best Version",
      "action": "select version with highest beat potential",
      "output": "recommendation"
    },
    {
      "step": 11,
      "name": "Save Output",
      "action": "write to output files",
      "output": "savedFiles"
    }
  ],

  "integration": {
    "judgeWorkflow": {
      "path": "../judge/workflow.md",
      "description": "Criteria alignment dengan Judge workflow",
      "scoreTargets": "Sync dengan Judge thresholds"
    },
    "rallyApi": {
      "baseUrl": "https://app.rally.fun/api",
      "endpoints": {
        "campaigns": "/campaigns",
        "leaderboard": "/leaderboard",
        "submissions": "/submissions"
      }
    },
    "webSearch": {
      "enabled": true,
      "provider": "z-ai-web-dev-sdk",
      "purpose": "Fresh data, fact verification, case studies"
    }
  }
}
